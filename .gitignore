# See https://docs.github.com/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# Compiled output
/dist
/tmp
/out-tsc
/bazel-out

# Node
/node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Environment files and local secrets
.env
.env.*
!.env.example
!.env.*.example

# Package and compiler artifacts
*.tgz
*.tsbuildinfo

# IDEs and editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.fleet/
.zed/
*.swp
*.swo
*~

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json
.history/*

# Miscellaneous
/.angular/
/.cache/
/.nx/
/.turbo/
/.vercel
.sass-cache/
.eslintcache
.stylelintcache
/connect.lock
/coverage
/libpeerconnection.log
testem.log
/typings
__screenshots__/

# End-to-end test output
/playwright-report/
/test-results/
/blob-report/

# Local AI assistant state
/.agents/
/.codex/

# System files
.DS_Store
Thumbs.db
Desktop.ini
