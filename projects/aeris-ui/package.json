    "theming",
    "ui"
  ],
  "peerDependencies": {
    "@angular/common": ">=22.0.6 <23.0.0",
    "@angular/core": ">=22.0.6 <23.0.0",
    "@angular/forms": ">=22.0.6 <23.0.0",
    "@angular/platform-browser": ">=22.0.6 <23.0.0",
    "rxjs": ">=7.8.0 <8.0.0",
    "chart.js": "^4.5.1",
    "@lexical/history": "^0.47.0",
    "@lexical/html": "^0.47.0",
    "@lexical/list": "^0.47.0",
    "@lexical/rich-text": "^0.47.0",
    "@lexical/selection": "^0.47.0",
    "lexical": "^0.47.0"
  },
  "peerDependenciesMeta": {
    "chart.js": {
      "optional": true
    },
    "@lexical/history": {
      "optional": true
    },
    "@lexical/html": {
      "optional": true
    },
    "@lexical/list": {
      "optional": true
    },
    "@lexical/rich-text": {
      "optional": true
    },
    "@lexical/selection": {
      "optional": true
    },
    "lexical": {
      "optional": true
    }
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "bin": {
    "aeris-theme": "./tools/aeris-theme.mjs"
  },
  "schematics": "./schematics/collection.json",
  "exports": {
