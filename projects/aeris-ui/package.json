  "description": "Accessible, themeable Angular UI components with signal-based APIs.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aeris-UI/AerisUI.git",
    "directory": "projects/aeris-ui"
  },
  "homepage": "https://aeris-ui.dev",
  "bugs": {
    "url": "https://github.com/Aeris-UI/AerisUI/issues"
  },
