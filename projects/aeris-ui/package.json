      "style": "./styles/controls.css",
      "default": "./styles/controls.css"
    },
    "./theming.scss": {
      "sass": "./styles/_index.scss"
    },
    "./theme-config.schema.json": "./tools/aeris-theme.schema.json",
    "./setup-config.schema.json": "./schematics/aeris-setup.schema.json"
  },
  "sideEffects": [
