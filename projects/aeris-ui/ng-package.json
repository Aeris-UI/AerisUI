{
  "$schema": "../../node_modules/ng-packagr/ng-package.schema.json",
  "dest": "../../dist/aeris-ui",
  "assets": [
    "LICENSE",
    {
      "glob": "**/*",
      "input": "src/styles",
      "output": "styles"
    },
    {
      "glob": "**/*",
      "input": "tools",
      "output": "tools"
    },
    {
      "glob": "**/*.json",
      "input": "schematics",
      "output": "schematics"
    }
  ],
  "lib": {
    "entryFile": "src/public-api.ts"
  }
}
