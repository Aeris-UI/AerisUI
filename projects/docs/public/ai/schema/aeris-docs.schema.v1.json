{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aeris-ui.dev/ai/schema/aeris-docs.schema.v1.json",
  "title": "Aeris AI documentation",
  "description": "Canonical, versioned machine-readable documentation for Aeris UI.",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schemaVersion", "library", "categories", "guides", "components"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "library": { "$ref": "#/$defs/library" },
    "categories": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "guides": {
      "type": "array",
      "items": { "$ref": "#/$defs/guide" }
    },
    "components": {
      "type": "array",
      "items": { "$ref": "#/$defs/component" }
    }
  },
  "$defs": {
    "library": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "status",
        "angularPeerRange",
        "documentationUrl",
        "repositoryUrl",
        "license",
        "styleImports",
        "peerDependencies",
        "principles"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "status": { "enum": ["alpha", "beta", "stable"] },
        "angularPeerRange": { "type": "string", "minLength": 1 },
        "documentationUrl": { "type": "string", "format": "uri" },
        "repositoryUrl": { "type": "string", "format": "uri" },
        "license": { "type": "string", "minLength": 1 },
        "styleImports": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        },
        "peerDependencies": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "principles": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["language", "label", "code"],
      "properties": {
        "language": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "code": { "type": "string", "minLength": 1 }
      }
    },
    "guide": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "group", "title", "description", "summary", "sections", "related"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "path": { "type": "string", "pattern": "^/" },
        "group": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/guideSection" }
        },
        "related": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" },
          "uniqueItems": true
        }
      }
    },
    "guideSection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "title": { "type": "string", "minLength": 1 },
        "advanced": { "type": "boolean" },
        "paragraphs": { "$ref": "#/$defs/nonEmptyStrings" },
        "bullets": { "$ref": "#/$defs/nonEmptyStrings" },
        "code": {
          "type": "array",
          "items": { "$ref": "#/$defs/source" }
        },
        "note": { "type": "string", "minLength": 1 },
        "table": { "$ref": "#/$defs/table" },
        "themePresets": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "name", "description"],
            "properties": {
              "id": { "$ref": "#/$defs/id" },
              "name": { "type": "string", "minLength": 1 },
              "description": { "type": "string", "minLength": 1 }
            }
          }
        },
        "links": {
          "type": "array",
          "items": { "$ref": "#/$defs/link" }
        }
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "href"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "href": { "type": "string", "minLength": 1 },
        "external": { "type": "boolean" }
      }
    },
    "table": {
      "type": "object",
      "additionalProperties": false,
      "required": ["caption", "columns", "rows"],
      "properties": {
        "caption": { "type": "string", "minLength": 1 },
        "columns": { "$ref": "#/$defs/nonEmptyStrings" },
        "rows": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "slug",
        "category",
        "description",
        "entryPoint",
        "documentationUrl",
        "imports",
        "importCode",
        "api",
        "referenceTables",
        "interfaces",
        "designTokens",
        "examples",
        "accessibility"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "slug": { "$ref": "#/$defs/id" },
        "category": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "entryPoint": { "type": "string", "pattern": "^@aeris-ui/core/" },
        "documentationUrl": { "type": "string", "format": "uri" },
        "imports": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        },
        "importCode": { "type": "string", "minLength": 1 },
        "api": {
          "type": "array",
          "items": { "$ref": "#/$defs/apiGroup" }
        },
        "referenceTables": {
          "type": "array",
          "items": { "$ref": "#/$defs/table" }
        },
        "interfaces": {
          "type": "array",
          "items": { "$ref": "#/$defs/interfaceBlock" }
        },
        "designTokens": {
          "type": "array",
          "items": { "$ref": "#/$defs/apiEntry" }
        },
        "examples": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/example" }
        },
        "accessibility": { "$ref": "#/$defs/accessibility" }
      }
    },
    "apiGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "kind", "entries"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "kind": {
          "enum": ["input", "model", "output", "template", "method", "property", "service", "other"]
        },
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/apiEntry" }
        }
      }
    },
    "apiEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "description"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "defaultValue": { "type": "string" },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "interfaceBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "code"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "code": { "type": "string", "minLength": 1 }
      }
    },
    "example": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "description", "sources"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/source" }
        }
      }
    },
    "accessibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["guidance", "keyboard"],
      "properties": {
        "guidance": { "$ref": "#/$defs/nonEmptyStrings" },
        "keyboard": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["keys", "behavior"],
            "properties": {
              "keys": { "type": "string", "minLength": 1 },
              "behavior": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[a-z0-9.-]*[a-z0-9])?$"
    },
    "nonEmptyStrings": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    }
  }
}
